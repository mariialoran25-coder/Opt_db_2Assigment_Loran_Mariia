DROP TABLE IF EXISTS opt_orders;
DROP TABLE IF EXISTS opt_products;
DROP TABLE IF EXISTS opt_clients;

CREATE TABLE IF NOT EXISTS opt_clients (
    id UUID PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    surname VARCHAR(255) NOT NULL,
    email VARCHAR(255) NOT NULL,
    phone VARCHAR(50) NOT NULL,
    address TEXT NOT NULL,
    status VARCHAR(20) NOT NULL CHECK (status IN ('active', 'inactive'))
);

CREATE TABLE IF NOT EXISTS opt_products (
    product_id INTEGER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    product_name VARCHAR(255) NOT NULL,
    product_category VARCHAR(50) NOT NULL CHECK (
        product_category IN ('Category1', 'Category2', 'Category3', 'Category4', 'Category5')
    ),
    description TEXT
);

CREATE TABLE IF NOT EXISTS opt_orders (
    order_id INTEGER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    order_date DATE NOT NULL,
    client_id UUID,
    product_id INTEGER,
    CONSTRAINT fk_opt_orders_client
        FOREIGN KEY (client_id) REFERENCES opt_clients(id),
    CONSTRAINT fk_opt_orders_product
        FOREIGN KEY (product_id) REFERENCES opt_products(product_id)
);
    -------------------------------------------------------------
    -------------------------------------------------------------
    -------------------------------------------------------------

BEGIN ;
set local enable_hashjoin = off; -- Коли я з'єднувала великі таблиці Join то Postgres сам обирає алгоритм як це зробити швидко. А вот Хеш джоін це і є 1 із алгоритмів
-- ще тут можна спробувати enable_seqscan, в Postgres муситиме використовувати Index Scan



-- EXAMPLE OF PEOPLE НЕ ОПТИМІЗОВАНА КВЕРЯ
EXPLAIN ANALYSE
SELECT (
    SELECT CONCAT(name, ': ', cnt)

    FROM (
        SELECT name,
               product_name,
                COUNT(*) AS cnt
        FROM (
            SELECT
                oc.name ,
                op.product_name
            FROM opt_orders AS oo
            JOIN opt_clients as oc ON oo.client_id = oc.id
            JOIN opt_products as op ON oo.product_id = op.product_id
            WHERE oc.email like '%@example.com' and  oc.status = 'active' AND oo.order_date > DATE '2024-08-18'
        ) AS sub1
        GROUP BY name , product_name
         ORDER BY name ASC
    )AS sub2
    WHERE cnt = (
        SELECT MIN(cnt)
        FROM (
            SELECT COUNT(*) AS cnt
            FROM (
                SELECT
                    oc.name ,
                    op.product_name

                FROM opt_orders AS oo
                JOIN opt_clients as oc ON oo.client_id = oc.id
                JOIN opt_products as op ON oo.product_id = op.product_id
                WHERE oc.email like '%@example.com' and oc.status = 'active'AND oo.order_date > DATE '2024-08-18'
                ) AS sub3
            GROUP BY name, product_name
            ORDER BY name ASC
        ) AS sub4
        ORDER BY name ASC
    )
     LIMIT 1
) AS min_cnt,

(
    SELECT CONCAT(name, ': ', cnt)
    FROM (
        SELECT name,
               product_name,
               COUNT(*) AS cnt
        FROM (
            SELECT
                oc.name ,
                op.product_name

            FROM opt_orders AS oo
            JOIN opt_clients as oc ON oo.client_id = oc.id
            JOIN opt_products as op ON oo.product_id = op.product_id
            WHERE  oc.email like '%@example.com' and oc.status = 'active' AND oo.order_date > DATE '2024-08-18'
        ) AS sub1
          GROUP BY name, product_name
           ORDER BY name ASC
    )AS sub2

    WHERE cnt = (
        SeLECT MAX(cnt)
        FROM (
            SELECT COUNT(*) AS cnt
            FROM (
                SELECT
                    oc.name ,
                    op.product_name

                FROM opt_orders AS oo
                JOIN opt_clients as oc ON oo.client_id = oc.id
                JOIN opt_products as op ON oo.product_id = op.product_id
                WHERE oc.email like '%@example.com' and  oc.status = 'active' AND oo.order_date > DATE '2024-08-18'
            ) AS sub3
               GROUP BY name, product_name
        ) AS sub4
    )
LIMIT 1
) AS max_cnt,

(
    SELECT CONCAT(name, ': ', cnt)
    FROM (
        SELECT name,
               product_name,
               COUNT(*) AS cnt
        FROM(
            SELECT name,
                   product_name
            FROM opt_orders AS oo
            JOIN opt_clients as oc ON oo.client_id = oc.id
            JOIN opt_products as op ON oo.product_id = op.product_id
           WHERE oc.email like '%@example.com' AND  oc.status = 'active'
                AND oo.order_date > DATE '2024-08-18'
            ) AS sub5

            GROUP BY name, product_name
            ORDER BY name ASC
        )AS sub6
    WHERE cnt = (
        SeLECT ROUND(AVG(cnt))
        FROM (
            SELECT COUNT(*) AS cnt
            FROM (
                SELECT name,
                       product_name
                FROM opt_orders AS oo
                JOIN opt_clients as oc ON oo.client_id = oc.id
                JOIN opt_products as op ON oo.product_id = op.product_id
                 WHERE oc.email like '%@example.com' AND  oc.status = 'active'
                AND oo.order_date > DATE '2024-08-18'
            ) AS sub7
                GROUP BY name, product_name
          ) As sum8
    )
    LIMIT 1
) AS avg_cnt;



--  ОПТИМІЗОВАНИЙ
CREATE INDEX IF NOT EXISTS idx_opt_clients_email
ON opt_clients(email);

CREATE INDEX IF NOT EXISTS idx_opt_clients_status
ON opt_clients(status);

CREATE INDEX IF NOT EXISTS idx_opt_orders_order_date
ON opt_orders(order_date);

CREATE INDEX IF NOT EXISTS idx_opt_orders_client_id
ON opt_orders(client_id);

CREATE INDEX IF NOT EXISTS idx_opt_orders_product_id
ON opt_orders(product_id);


---- 1 етап оптимізації ----
EXPLAIN ANALYSE
WITH filtered_customer_product AS (
    SELECT
        oc.name,
        op.product_name,
        COUNT(*) AS cnt
    FROM opt_orders AS oo
    JOIN opt_clients AS oc ON oo.client_id = oc.id
    JOIN opt_products AS op ON oo.product_id = op.product_id
    WHERE oc.email like '%@example.com' AND  oc.status = 'active'
      AND oo.order_date > DATE '2024-08-18'
    GROUP BY oc.name, op.product_name
),
stats AS (
    SELECT
        MIN(cnt) AS min_cnt,
        MAX(cnt) AS max_cnt,
        ROUND(AVG(cnt)) AS avg_cnt
    FROM filtered_customer_product
)
SELECT
    (SELECT CONCAT(name, ': ', cnt)
    FROM filtered_customer_product
    WHERE cnt = min_cnt
    ORDER BY name ASC
    LIMIT 1
) AS min_cnt,

(SELECT CONCAT(name, ': ', cnt)
    FROM filtered_customer_product
    WHERE cnt = max_cnt
    ORDER BY name ASC
    LIMIT 1
) AS max_cnt,

(SELECT CONCAT(name, ': ', cnt)
    FROM filtered_customer_product
    WHERE cnt = avg_cnt
    ORDER BY name ASC
    LIMIT 1
) AS avg_cnt
FROM  stats;

---------------------------------------------
---- 2 етап оптимізації ----

EXPLAIN ANALYSE
WITH filtered_customer_product AS (
    SELECT
        oc.name,
        op.product_name
        --COUNT(*) AS cnt
    FROM opt_orders AS oo
    JOIN opt_clients AS oc ON oo.client_id = oc.id
    JOIN opt_products AS op ON oo.product_id = op.product_id
    WHERE oc.email like '%@example.com' AND  oc.status = 'active'
      AND oo.order_date > DATE '2024-08-18'
),
cnt_product AS (
    SELECT
        name,
        product_name,
        count(*) AS cnt
    FROM filtered_customer_product
    GROUP BY name, product_name
),
stats AS (
    SELECT
        name,
        product_name,
        cnt,
        row_number() over (ORDER BY cnt ASC, name aSC) as rn_min,
        row_number() over (ORDER BY cnt deSC, name aSC) as rn_max,
        ROUND(AVG(cnt) over()) AS avg_cn
    FROM cnt_product
)
SELECT
    (SELECT concat(name, ': ', cnt) FROM stats WHERE rn_min = 1) AS min_cnt,
    (SELECT concat(name, ': ', cnt) FROM stats WHERE rn_max = 1) AS max_cnt,
    (SELECT concat(name, ': ', avg_cn) FROM stats Order by name asc LIMIT 1) AS avg_cnt;


---------------------------------------------
---- 3 етап оптимізації ----

EXPLAIN ANALYSE
WITH stats AS (
    SELECT
        oc.name,
        op.product_name,
        COUNT(*) AS cnt,
        row_number() over (ORDER BY COUNT(*) ASC, name aSC) as rn_min,
        row_number() over (ORDER BY COUNT(*) deSC, name aSC) as rn_max,
        ROUND(AVG(COUNT(*)) over()) AS avg_cn
    FROM opt_orders AS oo
    JOIN opt_clients AS oc ON oo.client_id = oc.id
    JOIN opt_products AS op ON oo.product_id = op.product_id
    WHERE oc.email like '%@example.com' AND  oc.status = 'active'
      AND oo.order_date > DATE '2024-08-18'
    GROUP BY name, product_name
)
SELECT
    (SELECT concat(name, ': ', cnt) FROM stats WHERE rn_min = 1) AS min_cnt,
    (SELECT concat(name, ': ', cnt) FROM stats WHERE rn_max = 1) AS max_cnt,
    (SELECT concat(name, ': ', avg_cn) FROM stats Order by name asc LIMIT 1) AS avg_cnt;



---------------------------------------------
---- 4 етап оптимізації FINAL  ----

EXPLAIN ANALYSE
WITH stats AS (
    SELECT
        oc.name,
        op.product_name,
        COUNT(*) AS cnt
    FROM opt_orders AS oo
    JOIN opt_clients AS oc ON oo.client_id = oc.id
    JOIN opt_products AS op ON oo.product_id = op.product_id
    WHERE oc.email like '%@example.com' AND  oc.status = 'active'
      AND oo.order_date > DATE '2024-08-18'
    GROUP BY name, product_name
)
SELECT
    (SELECT concat(name, ': ', cnt) FROM stats ORDER BY cnt ASC, name ASC LIMIT  1) AS min_cnt,
    (SELECT concat(name, ': ', cnt) FROM stats ORDER BY cnt DESC, name ASC LIMIT  1) AS max_cnt,
    (SELECT concat(name, ': ', ROUND(AVG(cnt) OVER()) ) FROM stats Order by name asc LIMIT 1) AS avg_cnt;

ROLLBACK ;


